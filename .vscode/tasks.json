{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "Build Native",
      "type": "shell",
      "command": "cmake --build build/native",
      "group": "build"
    },

    {
      "label": "Build AArch64",
      "type": "shell",
      "command": "cmake --build build/aarch64",
      "group": "build"
    },
    {
      "label": "Deploy AArch64",
      "type": "shell",
      "command": "scp -i /root/.ssh/boxssh_rsa build/aarch64/src/sysnet deva@${config:debug.targetHost}:/home/deva/sysnet.new && ssh -i /root/.ssh/boxssh_rsa deva@${config:debug.targetHost} 'mv /home/deva/sysnet.new /home/deva/sysnet'",
      "problemMatcher": []
    },
    {
      "label": "Run gdbserver",
      "type": "shell",
      "command": "ssh -i /root/.ssh/boxssh_rsa deva@${config:debug.targetHost} 'pkill gdbserver || true; nohup gdbserver :${config:debug.targetPort} /home/deva/sysnet > /tmp/sysnet.log 2>&1 &'",
      "problemMatcher": []
    },
    {
      "label": "Tail sysnet log",
      "type": "shell",
      "command": "ssh -i /root/.ssh/boxssh_rsa deva@${config:debug.targetHost} 'tail -f /tmp/sysnet.log'"
    },
    {
      "label": "Wait for gdbserver",
      "type": "shell",
      "command": "sleep 1"
    },   
    {
      "label": "Build+Deploy+Run AArch64",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build AArch64",
        "Deploy AArch64",
        "Run gdbserver"
        //"Wait for gdbserver"
      ]
    }
  ]
}